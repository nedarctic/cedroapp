generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Booking {
  id        String   @id @default(uuid())
  name      String
  email     String
  tourTitle String
  createdAt DateTime @default(now())
}

model Contact {
  id        String   @id @default(uuid())
  name      String
  email     String
  message   String
  createdAt DateTime @default(now())
}

model subscription {
  id        String   @id @default(uuid())
  email     String   @unique
  createdAt DateTime @default(now())
}
